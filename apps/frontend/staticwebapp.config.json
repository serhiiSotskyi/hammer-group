      "/uploads/*",
      "/favicon.ico",
      "/robots.txt",
      "/sitemap.xml",
      "*.css",
      "*.js",
      "*.mjs",
      "*.map",
      "*.json",
      "*.ico",
      "*.png",
      "*.jpg",
      "*.jpeg",
      "*.gif",
      "*.svg",
      "*.webp",
      "*.woff",
      "*.woff2"
    ]
